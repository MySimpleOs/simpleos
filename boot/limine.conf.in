# SimpleOS — Limine bootloader configuration.
# __LIMINE_RESOLUTION__ is filled by scripts/gen-limine-conf.sh from
# rootfs/etc/display.conf at ISO build.
# Reference: https://github.com/limine-bootloader/limine/blob/trunk/CONFIG.md

timeout: 0
default_entry: 1

/SimpleOS
    protocol: limine
__LIMINE_RESOLUTION__
    kernel_path: boot():/boot/simpleos.elf
    module_path: boot():/boot/initrd.tar
