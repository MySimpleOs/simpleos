# SimpleOS bootloader version pins.
# Override any of these via environment before running scripts/fetch-limine.sh.

# Upstream Limine binary branch. Bump the major version (v10.x-binary, …)
# when you want to adopt a new Limine release series.
LIMINE_VERSION="${LIMINE_VERSION:-v9.x-binary}"
LIMINE_REPO="${LIMINE_REPO:-https://github.com/limine-bootloader/limine.git}"
